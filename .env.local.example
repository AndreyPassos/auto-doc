# Local development — used by start.sh
# Copy to .env.local and fill in your values.

# PostgreSQL running locally (e.g. via brew services or docker compose postgres only)
DATABASE_URL=postgres://autodoc:changeme_in_production@localhost:5432/autodoc?sslmode=disable

# Security
JWT_SECRET=local_dev_secret_change_me_32chars_min
JWT_EXPIRY_HOURS=24

# Server
PORT=8080
ENV=development
WORKER_POOL_SIZE=2
UPLOAD_DIR=/tmp/autodoc-uploads

# Frontend dev server port (optional, default 5173)
# FRONTEND_PORT=5173

# Admin seed (first boot only)
ADMIN_EMAIL=admin@autodoc.local
ADMIN_PASSWORD=changeme123
