# PostgreSQL
POSTGRES_USER=autodoc
POSTGRES_PASSWORD=changeme_in_production
POSTGRES_DB=autodoc

# Backend
DATABASE_URL=postgres://autodoc:changeme_in_production@postgres:5432/autodoc?sslmode=disable
JWT_SECRET=change_this_to_a_random_secret_of_at_least_32_characters
JWT_EXPIRY_HOURS=24
UPLOAD_DIR=/var/uploads
ENV=production
WORKER_POOL_SIZE=4

# Admin seed (used only on first startup if no users exist)
ADMIN_EMAIL=admin@autodoc.local
ADMIN_PASSWORD=changeme_admin_password
